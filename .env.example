# Sao chép file này thành `.env` để tham khảo các biến môi trường cần thiết.
#
# LƯU Ý: Spring Boot KHÔNG tự động đọc file `.env`. Muốn dùng khi chạy local,
# export các biến vào shell trước khi chạy Maven (Git Bash):
#   set -a && source .env && set +a && mvn spring-boot:run -Dspring-boot.run.profiles=dev
# Khi deploy (Railway, Docker, ...), nhập các biến này vào phần Variables/
# Environment của nền tảng — KHÔNG commit file `.env` thật (đã bị .gitignore).
# Mọi biến đều có giá trị mặc định an toàn cho dev trong application.yml, nên
# .env chỉ thực sự bắt buộc khi deploy production.

# --- Database (Postgres) ---
SHAREBILL_DB_URL=jdbc:postgresql://localhost:5433/sharebill
SHAREBILL_DB_USER=sharebill
SHAREBILL_DB_PASSWORD=sharebill

# --- Auth (JWT) ---
# BẮT BUỘC đổi khi deploy production — chuỗi ngẫu nhiên, đủ dài (>= 32 ký tự).
SHAREBILL_JWT_SECRET=dev-only-secret-change-me-0123456789abcdef0123456789abcdef

# --- CORS ---
# Danh sách origin của frontend, phân cách bằng dấu phẩy, KHÔNG có khoảng trắng.
SHAREBILL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# --- Cloudinary (upload avatar) ---
# Để trống nếu chưa cấu hình — nút "Tải ảnh" trong Profile sẽ báo lỗi khi bấm,
# nhưng avatar mẫu (DiceBear preset) vẫn hoạt động bình thường.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Server ---
PORT=8088

# --- Spring profile ---
# "dev" bật DevDataSeeder (tạo user demo@sharebill.local + dữ liệu mẫu).
# Bỏ trống hoặc xóa dòng này cho production.
SPRING_PROFILES_ACTIVE=dev
